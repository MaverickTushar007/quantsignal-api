{
  "build": {
    "builder": "DOCKERFILE"
  },
  "deploy": {
    "cronJobs": [
      {
        "schedule": "*/15 * * * *",
        "command": "curl -s -X POST http://localhost:8080/api/v1/cron/check-outcomes -H 'X-Cron-Secret: quantsignal_cron_2026'"
      },
      {
        "schedule": "*/15 * * * *", 
        "command": "curl -s -X POST http://localhost:8080/api/v1/cron/refresh -H 'X-Cron-Secret: quantsignal_cron_2026'"
      }
    ]
  }
}
